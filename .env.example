# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: News feed ────────────────────────────────────────────────────────
# Get a free key at https://newsapi.org
NEWSAPI_KEY=

# ── Claude model ──────────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-opus-4-6

# ── Market filters ─────────────────────────────────────────────────────────────
MIN_LIQUIDITY_USD=10000
MIN_DAYS_TO_CLOSE=3
MAX_DAYS_TO_CLOSE=180

# ── Edge / confidence thresholds ───────────────────────────────────────────────
# MIN_EDGE_PCT: minimum |AI estimate - market price| to flag an opportunity
MIN_EDGE_PCT=8
# CONFIDENCE_THRESHOLD: minimum confidence to open a position
CONFIDENCE_THRESHOLD=0.6

# ── Position sizing ────────────────────────────────────────────────────────────
# KELLY_FRACTION: fractional Kelly multiplier — reduced to 0.15x based on live Brier data
KELLY_FRACTION=0.15
# MAX_POSITION_PCT: hard cap — max % of bankroll for any single position
MAX_POSITION_PCT=3
# NO_TRADE_WINDOW_HOURS: hours before resolution where no new positions are opened
NO_TRADE_WINDOW_HOURS=2
# CORRELATION_CLUSTER_MAX: max positions sharing same resolution event before penalty kicks in
CORRELATION_CLUSTER_MAX=3
# Starting paper bankroll (USD)
PAPER_BANKROLL_USD=1000

# ── Scan loop ─────────────────────────────────────────────────────────────────
SCAN_INTERVAL_MS=300000
MARKETS_PER_SCAN=50
TOP_N_TO_ANALYZE=10

# ── Misc ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
# DRY_RUN=false  # set to false to enable live position tracking
DRY_RUN=true

